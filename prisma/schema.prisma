generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Post {
  id           String   @id @default(uuid())
  instagramId  String   @unique
  username     String
  postUrl      String
  likesCount   Int      @default(0)
  thumbnailUrl String?
  publishedAt  DateTime
  lastUpdated  DateTime @default(now())
}
